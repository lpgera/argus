{
  "author": "lpgera",
  "name": "argus",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^26.0.0",
    "npm": ">11.0.0"
  },
  "volta": {
    "node": "26.3.0"
  },
  "scripts": {
    "build": "npm run build -w frontend",
    "seed": "npm run seed -w backend",
    "start": "npm run start -w backend",
    "docker:bootstrap": "docker compose run --rm backend npm i",
    "docker:seed": "docker compose run --rm backend npm run seed",
    "docker:up": "docker compose up -d && docker-compose logs -tf",
    "docker:build": "docker compose run --rm backend npm run build",
    "docker:logs": "docker compose logs -tf",
    "docker:down": "docker compose down --remove-orphans",
    "prepare": "husky || true",
    "check-updates": "ncu -i -w",
    "browserslist-update": "npx update-browserslist-db@latest"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-check-updates": "^22.2.3",
    "prettier": "^3.8.4"
  },
  "workspaces": [
    "./packages/*",
    "./packages/clients/*"
  ],
  "lint-staged": {
    "*.{js,jsx,css,md,json,yml}": "prettier --write"
  },
  "allowScripts": {
    "@serialport/bindings-cpp@13.0.0": true,
    "@serialport/bindings-cpp@12.0.1": true,
    "@stoprocent/bluetooth-hci-socket@2.2.6": true,
    "@stoprocent/noble@2.5.4": true,
    "epoll@4.0.2": true,
    "fsevents@2.3.3": true,
    "i2c-bus@5.2.3": true,
    "node-dht-sensor@0.5.1": true,
    "usb@2.17.0": true
  }
}
